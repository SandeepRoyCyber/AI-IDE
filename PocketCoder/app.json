{
  "expo": {
    "name": "PocketCoder",
    "slug": "pocketcoder",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "pocketcoder",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.pocketcoder.app",
      "infoPlist": {
        "UIFileSharingEnabled": true,
        "LSSupportsOpeningDocumentsInPlace": true,
        "NSDocumentsFolderUsageDescription": "PocketCoder needs access to store AI models",
        "NSLocalNetworkUsageDescription": "Used for development server"
      }
    },
    "plugins": [
      "expo-document-picker"
    ]
  }
}
